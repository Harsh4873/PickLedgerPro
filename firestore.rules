rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwnUserDoc(userId) {
      return request.auth != null && (
        request.auth.uid == userId ||
        (request.auth.token.email != null && request.auth.token.email == userId)
      );
    }

    // Admin picks cache - readable by any signed-in user, writable only by Admin SDK.
    match /admin_picks/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user data - each user can only read and write their own document.
    match /users/{userId} {
      allow read, write: if isOwnUserDoc(userId);
    }

    // Legacy per-user subcollections retained for backward compatibility.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwnUserDoc(userId);
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
